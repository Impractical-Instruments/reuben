# Build-generated staging target: the wasm, the schema, and the discovered instrument
# bundle are produced by scripts/stage-assets.mjs (npm run stage) from the workspace —
# never committed, always regenerated. Keeping public/ out of git is the point of the
# staging script (ADR-0041: /web owns only the launcher + shell + build config).
/public/

# Offline-precache list emitted by stage-assets.mjs (issue #227): the transitive-discovery
# output vite.config.js hands to Workbox. Build-generated, never committed — same rationale
# as public/ above.
/.pwa-precache.json

# Vite build output and Playwright artifacts.
/dist/
/test-results/
/playwright-report/
/.playwright/

# Dependencies.
/node_modules/
