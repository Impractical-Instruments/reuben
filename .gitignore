# Rust
/target
**/*.rs.bk

# Generated audio (example output, e.g. first_sound.wav)
*.wav
# ...but committed sample fixtures (worked-example instruments) are kept.
!instruments/samples/*.wav
# ...and the frozen test/bench fixture samples (library cull relocated them out of instruments/).
!**/fixtures/samples/*.wav

# Perf-gate harvest record (regenerated each run by perf-gate.sh; lives on the bench-history branch)
/bench-history-record.jsonl

# Editor / OS
*.swp
*.bak
.DS_Store
.idea/
.junie/

# Claude Code worktrees
/.claude/worktrees/

# Wrangler's local cache (writes account_id into the working tree)
.wrangler/

# Python bytecode, wherever it lands. Unanchored on purpose: the rules-doc scripts live in
# /scripts, but the skills ship their own Python too (absorb-adrs, control-surface), and running
# any of their test suites drops a __pycache__ next to the source. A /scripts-only rule let two
# .pyc blobs into #555.
__pycache__/
*.py[cod]
