{
  "format_version": 2,
  "instrument": "strum-harp-voice",
  "doc": "Voice patch for strum-harp.json (ADR-0032). One monophonic plucked saw voice: a held freq drives the oscillator, a held gate the percussive ADSR (near-instant attack, short decay, long release — each pluck rings out). NO filter here — the brightness Good Button drives a single master filter on the summed mix (host post-mix), so the voice is just osc -> env VCA. interface: freq/gate in, audio/active out.",
  "interface": {
    "inputs": {
      "freq": {
        "type": "f32_buffer",
        "default": 440.0,
        "min": 20.0,
        "max": 20000.0,
        "curve": "exp",
        "unit": "Hz"
      },
      "gate": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 1.0
      }
    },
    "outputs": {
      "active": {
        "from": "/env.active"
      },
      "audio": {
        "from": "/out.audio"
      }
    }
  },
  "nodes": [
    {
      "type": "oscillator",
      "address": "/osc",
      "doc": "Saw",
      "inputs": {
        "freq": {
          "from": "/freq"
        },
        "waveform": "Saw"
      }
    },
    {
      "type": "envelope",
      "address": "/env",
      "doc": "Percussive pluck: near-instant attack, short decay, no sustain — each pluck rings out on its own. Gated by the voicer; the strum op's paired note-off frees the voice.",
      "inputs": {
        "attack": 0.002,
        "decay": 0.0,
        "gate": {
          "from": "/gate"
        },
        "release": 0.8,
        "sustain": 1.0
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/env_vca",
      "doc": "VCA: saw * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/osc"
        },
        "b": {
          "from": "/env_curve"
        }
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      }
    }
  ]
}
