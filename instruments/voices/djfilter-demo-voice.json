{
  "format_version": 2,
  "instrument": "djfilter-demo-voice",
  "doc": "Voice patch for djfilter-demo.json (ADR-0032). One monophonic plucky saw voice: a held freq drives the oscillator, a held gate the plucky ADSR. NO djfilter here — the bipolar filter knob drives a single master djfilter on the summed mix (host post-mix), so the voice is just osc -> env VCA. interface: freq/gate in, audio/active out.",
  "interface": {
    "inputs": {
      "freq": {
        "type": "f32_buffer",
        "default": 440.0,
        "min": 20.0,
        "max": 20000.0,
        "curve": "exp",
        "unit": "Hz"
      },
      "gate": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 1.0
      }
    },
    "outputs": {
      "active": {
        "from": "/env.active"
      },
      "audio": {
        "from": "/out.audio"
      }
    }
  },
  "nodes": [
    {
      "type": "oscillator",
      "address": "/osc",
      "doc": "Saw tone (rich harmonics for the master filter to chew).",
      "inputs": {
        "freq": {
          "from": "/freq"
        },
        "waveform": "Saw"
      }
    },
    {
      "type": "envelope",
      "address": "/env",
      "doc": "Plucky ADSR envelope (linear CV), gated per step.",
      "inputs": {
        "attack": 0.01,
        "decay": 0.15,
        "gate": {
          "from": "/gate"
        },
        "release": 0.2,
        "sustain": 0.5
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/env_vca",
      "doc": "VCA: saw * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/osc"
        },
        "b": {
          "from": "/env_curve"
        }
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      }
    }
  ]
}
