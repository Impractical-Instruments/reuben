{
  "doc": "Voice patch for auto-filter.json (ADR-0032). One monophonic saw synth voice: a held freq drives the oscillator, a held gate the ADSR. NO filter here — the base-plus-LFO cutoff drives a single master filter on the summed mix (host post-mix), so the voice is just osc -> env VCA. interface: freq/gate in, audio/active out.",
  "instrument": "auto-filter-voice",
  "interface": {
    "inputs": {
      "freq": "/osc.freq",
      "gate": "/env.gate"
    },
    "outputs": {
      "audio": "/out.audio",
      "active": "/env.active"
    }
  },
  "nodes": [
    {
      "address": "/osc",
      "inputs": {
        "waveform": "Saw"
      },
      "type": "oscillator"
    },
    {
      "address": "/env",
      "type": "envelope"
    },
    {
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/env_vca",
      "doc": "VCA: saw * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/osc"
        },
        "b": {
          "from": "/env_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      },
      "type": "output"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
