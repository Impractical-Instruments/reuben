{
  "doc": "Hi-hat voice (ADR-0032). A gate fires a short envelope shaping highpassed noise into a metallic tick. Pitch is internal (no freq interface input); the host's lane voicer only drives the gate. interface: gate in, audio/active out.",
  "instrument": "hat-voice",
  "interface": {
    "inputs": {
      "gate": "/env.gate"
    },
    "outputs": {
      "audio": "/out.audio",
      "active": "/env.active"
    }
  },
  "nodes": [
    {
      "address": "/noise",
      "doc": "Hat noise source.",
      "type": "noise"
    },
    {
      "address": "/hp",
      "doc": "Highpass to thin the noise into a metallic hat.",
      "inputs": {
        "audio": {
          "from": "/noise"
        },
        "cutoff": 7000.0,
        "mode": "Hp",
        "resonance": 0.1
      },
      "type": "filter"
    },
    {
      "address": "/env",
      "doc": "Very short amplitude envelope -> linear CV -> tick.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.04,
        "release": 0.03,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/curve",
      "doc": "Exponential-style volume curve (x^2) on the hat CV.",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/vca",
      "doc": "VCA: hat noise * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/hp"
        },
        "b": {
          "from": "/curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/vca"
        }
      },
      "type": "output"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
