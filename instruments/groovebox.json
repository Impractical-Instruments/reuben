    {
      "type": "voicer",
      "address": "/hat_v",
      "doc": "Hosts the hat-voice; the lane's gate fires it.",
      "config": {
        "voices": 1.0
      },
      "inputs": {
        "notes": {
          "from": "/hat"
        }
      },
      "voice": "hat-voice"
    },
    {
      "type": "m2s",
      "address": "/kick_vol_cv",
      "doc": "Smooths the /kick_vol pipe (kick lane volume [0,1]) into a CV (m2s = value->signal).",
      "inputs": {
        "in": {
          "from": "/kick_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/kick_amp",
      "doc": "kick audio * volume CV.",
      "inputs": {
        "a": {
          "from": "/kick_v.audio"
        },
        "b": {
          "from": "/kick_vol_cv"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/snare_vol_cv",
      "doc": "Smooths the /snare_vol pipe (snare lane volume [0,1]) into a CV.",
      "inputs": {
        "in": {
          "from": "/snare_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/snare_amp",
      "doc": "snare audio * volume CV.",
      "inputs": {
        "a": {
          "from": "/snare_v.audio"
        },
        "b": {
          "from": "/snare_vol_cv"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/hat_vol_cv",
      "doc": "Smooths the /hat_vol pipe (hat lane volume [0,1]) into a CV.",
      "inputs": {
        "in": {
          "from": "/hat_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/hat_amp",
      "doc": "hat audio * volume CV.",
      "inputs": {
        "a": {
          "from": "/hat_v.audio"
        },
        "b": {
          "from": "/hat_vol_cv"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix_a",
      "doc": "kick (a) + snare (b).",
      "inputs": {
        "a": {
          "from": "/kick_amp"
        },
        "b": {
          "from": "/snare_amp"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix",
      "doc": "(kick+snare) (a) + hat (b) -> full drum mix.",
      "inputs": {
        "a": {
          "from": "/mix_a"
        },
        "b": {
          "from": "/hat_amp"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/drive_cv",
      "doc": "Smooths the /drive pipe (saturator drive [1,30], rests at 3) into a CV.",
      "inputs": {
        "in": {
          "from": "/drive"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "saturator",
      "address": "/sat",
      "doc": "Warm tanh glue on the full drum mix; peak-normalized, so overlapping hits squash instead of clipping (retires the old constant headroom trim). Drive rides the /drive knob.",
      "inputs": {
        "audio": {
          "from": "/mix"
        },
        "drive": {
          "from": "/drive_cv"
        },
        "warmth": 0.5
      }
    },
    {
      "type": "m2s",
      "address": "/tone_cv",
      "doc": "Smooths the /tone pipe (master DJ-filter knob [0,1], rests at 0.5 = neutral) into a CV (m2s = value->signal), then ranged into the DJ filter position.",
      "inputs": {
        "in": {
          "from": "/tone"
        },
        "mode": "Smooth",
        "time": 0.03
      }
    },
    {
      "type": "map_f32_signal",
      "address": "/pos_map",
      "doc": "tone [0,1] -> DJ position [-1,1]: 0.5 = neutral, below sweeps the lowpass, above the highpass.",
      "inputs": {
        "curve": "Linear",
        "in": {
          "from": "/tone_cv"
        },
        "out_max": 1.0,
        "out_min": -1.0
      }
    },
    {
      "type": "djfilter",
      "address": "/master",
      "doc": "Master DJ filter over the saturated kit; one knob sweeps lowpass (left) to highpass (right), neutral at center.",
      "inputs": {
        "audio": {
          "from": "/sat"
        },
        "position": {
          "from": "/pos_map"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/volume_cv",
      "doc": "Smooths the /volume pipe (main volume knob [0,1], rests at 0.5 = -6 dB) into a CV.",
      "inputs": {
        "in": {
          "from": "/volume"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/vol",
      "doc": "master audio * main volume CV -> final level.",
      "inputs": {
        "a": {
          "from": "/master"
        },
        "b": {
          "from": "/volume_cv"
        }
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/vol"
        }
      }
    }
  ]
}
