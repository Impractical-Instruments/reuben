        "notes": {
          "from": "/hat"
        }
      },
      "type": "voicer"
    },
    {
      "address": "/kick_sweep_amt",
      "doc": "Constant pitch-sweep amount (Hz) for the kick pitch-drop.",
      "inputs": {
        "in": 220.0
      },
      "type": "m2s"
    },
    {
      "address": "/kick_penv",
      "doc": "Pitch-drop envelope generator -> linear CV, very fast decay -> the kick 'thump'.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.06,
        "gate": {
          "from": "/kick_v.gate"
        },
        "release": 0.06,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/kick_penv_vca",
      "doc": "Scale the sweep amount by the (linear) pitch envelope CV.",
      "inputs": {
        "a": {
          "from": "/kick_sweep_amt"
        },
        "b": {
          "from": "/kick_penv.cv"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/kick_base",
      "doc": "Constant kick base frequency (Hz).",
      "inputs": {
        "in": 48.0
      },
      "type": "m2s"
    },
    {
      "address": "/kick_freq",
      "doc": "kick freq = base (a) + decaying sweep (b).",
      "inputs": {
        "a": {
          "from": "/kick_base"
        },
        "b": {
          "from": "/kick_penv_vca"
        }
      },
      "type": "add_f32_signal"
    },
    {
      "address": "/kick_osc",
      "doc": "Sine body, frequency driven by the pitch-drop.",
      "inputs": {
        "freq": {
          "from": "/kick_freq"
        },
        "waveform": "Sine"
      },
      "type": "oscillator"
    },
    {
      "address": "/kick_aenv",
      "doc": "Amplitude envelope generator -> linear CV, fast decay.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.12,
        "gate": {
          "from": "/kick_v.gate"
        },
        "release": 0.08,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/kick_aenv_curve",
      "doc": "Exponential-style volume curve (x^2) on the kick amp CV.",
      "inputs": {
        "x": {
          "from": "/kick_aenv.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/kick_aenv_vca",
      "doc": "VCA: kick body * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/kick_osc"
        },
        "b": {
          "from": "/kick_aenv_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/snare_noise",
      "doc": "Snare noise body.",
      "type": "noise"
    },
    {
      "address": "/snare_nenv",
      "doc": "Noise amplitude envelope generator -> linear CV, short snap.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.09,
        "gate": {
          "from": "/snare_v.gate"
        },
        "release": 0.06,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/snare_nenv_curve",
      "doc": "Exponential-style volume curve (x^2) on the snare-noise CV.",
      "inputs": {
        "x": {
          "from": "/snare_nenv.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/snare_nenv_vca",
      "doc": "VCA: snare noise * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/snare_noise"
        },
        "b": {
          "from": "/snare_nenv_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/snare_tone_f",
      "doc": "Constant tonal frequency (Hz) for the snare's ring.",
      "inputs": {
        "in": 185.0
      },
      "type": "m2s"
    },
    {
      "address": "/snare_osc",
      "doc": "Tonal component (sine) under the noise.",
      "inputs": {
        "freq": {
          "from": "/snare_tone_f"
        },
        "waveform": "Sine"
      },
      "type": "oscillator"
    },
    {
      "address": "/snare_tenv",
      "doc": "Tonal amplitude envelope generator -> linear CV, very short.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.05,
        "gate": {
          "from": "/snare_v.gate"
        },
        "release": 0.04,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/snare_tenv_curve",
      "doc": "Exponential-style volume curve (x^2) on the snare-tone CV.",
      "inputs": {
        "x": {
          "from": "/snare_tenv.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/snare_tenv_vca",
      "doc": "VCA: snare tone * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/snare_osc"
        },
        "b": {
          "from": "/snare_tenv_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/snare_mix",
      "doc": "snare = noise body (a) + tonal ring (b).",
      "inputs": {
        "a": {
          "from": "/snare_nenv_vca"
        },
        "b": {
          "from": "/snare_tenv_vca"
        }
      },
      "type": "add_f32_signal"
    },
    {
      "address": "/hat_noise",
      "doc": "Hat noise source.",
      "type": "noise"
    },
    {
      "address": "/hat_hp",
      "doc": "Highpass (mode=1) to thin the noise into a metallic hat.",
      "inputs": {
        "audio": {
          "from": "/hat_noise"
        },
        "cutoff": 7000.0,
        "mode": "Hp",
        "resonance": 0.1
      },
      "type": "filter"
    },
    {
      "address": "/hat_env",
      "doc": "Very short amplitude envelope generator -> linear CV -> tick.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.04,
        "gate": {
          "from": "/hat_v.gate"
        },
        "release": 0.03,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/hat_env_curve",
      "doc": "Exponential-style volume curve (x^2) on the hat CV.",
      "inputs": {
        "x": {
          "from": "/hat_env.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/hat_env_vca",
      "doc": "VCA: hat noise * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/hat_hp"
        },
        "b": {
          "from": "/hat_env_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/kick_vol",
      "control": {
        "label": "Kick Vol",
        "widget": "fader"
      },
      "doc": "Kick lane volume Good Button [0,1].",
      "inputs": {
        "in": 0.7
      },
      "type": "map"
    },
    {
      "address": "/kick_vol_cv",
      "doc": "Smooth kick volume into a constant CV.",
      "inputs": {
        "in": {
          "from": "/kick_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      },
      "type": "m2s"
    },
    {
      "address": "/kick_amp",
      "doc": "kick audio * volume CV.",
      "inputs": {
        "a": {
          "from": "/kick_aenv_vca"
        },
        "b": {
          "from": "/kick_vol_cv"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/snare_vol",
      "control": {
        "label": "Snare Vol",
        "widget": "fader"
      },
      "doc": "Snare lane volume Good Button [0,1].",
      "inputs": {
        "in": 0.5
      },
      "type": "map"
    },
    {
      "address": "/snare_vol_cv",
      "doc": "Smooth snare volume into a constant CV.",
      "inputs": {
        "in": {
          "from": "/snare_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      },
      "type": "m2s"
    },
    {
      "address": "/snare_amp",
      "doc": "snare audio * volume CV.",
      "inputs": {
        "a": {
          "from": "/snare_mix"
        },
        "b": {
          "from": "/snare_vol_cv"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/hat_vol",
      "control": {
        "label": "Hat Vol",
        "widget": "fader"
      },
      "doc": "Hat lane volume Good Button [0,1].",
      "inputs": {
        "in": 0.35
      },
      "type": "map"
    },
    {
      "address": "/hat_vol_cv",
      "doc": "Smooth hat volume into a constant CV.",
      "inputs": {
        "in": {
          "from": "/hat_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      },
      "type": "m2s"
    },
    {
      "address": "/hat_amp",
      "doc": "hat audio * volume CV.",
      "inputs": {
        "a": {
          "from": "/hat_env_vca"
        },
        "b": {
          "from": "/hat_vol_cv"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/mix_a",
      "doc": "kick (a) + snare (b).",
      "inputs": {
        "a": {
          "from": "/kick_amp"
        },
        "b": {
          "from": "/snare_amp"
        }
      },
      "type": "add_f32_signal"
    },
    {
      "address": "/mix",
      "doc": "(kick+snare) (a) + hat (b) -> full drum mix.",
      "inputs": {
        "a": {
          "from": "/mix_a"
        },
        "b": {
          "from": "/hat_amp"
        }
      },
      "type": "add_f32_signal"
    },
    {
      "address": "/master",
      "doc": "Master lowpass (mode=0); cutoff is a Good Button to tone the whole kit.",
      "inputs": {
        "audio": {
          "from": "/mix"
        },
        "cutoff": {
          "from": "/cutoff_cv"
        }
      },
      "type": "filter"
    },
    {
      "address": "/trim_cv",
      "doc": "Constant master trim (headroom so overlapping hits don't clip).",
      "inputs": {
        "in": 0.7
      },
      "type": "m2s"
    },
    {
      "address": "/trim",
      "doc": "master audio * trim CV -> headroom.",
      "inputs": {
        "a": {
          "from": "/master"
        },
        "b": {
          "from": "/trim_cv"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/trim"
        }
      },
      "type": "output"
    },
    {
      "address": "/cutoff",
      "control": {
        "label": "Tone",
        "widget": "fader"
      },
      "doc": "PUBLIC master-filter Good Button: brightness [0,1] -> cutoff. Rests at 0.8.",
      "inputs": {
        "curve": "Exponential",
        "in": 0.8,
        "out_max": 16000.0,
        "out_min": 500.0
      },
      "type": "map"
    },
    {
      "address": "/cutoff_cv",
      "doc": "Smooth the master cutoff into a CV.",
      "inputs": {
        "in": {
          "from": "/cutoff"
        },
        "mode": "Smooth",
        "time": 0.03
      },
      "type": "m2s"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
