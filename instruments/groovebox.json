{
  "instrument": "groovebox",
  "doc": "A free-running synthesized step-sequenced beatmaker (V1.3 Toy 1, ADR-0022). Three lanes — kick, snare, hat — each a 16-step boolean gate sequencer (gate_mode=1) driving a one-voice drum synth built entirely from operators (no samples). One shared clock at division=4 makes a 16th-note grid; the pattern loops forever, instant sound, no transport. Toggle steps with /kick/step1../kick/step16 (and /snare/*, /hat/*); each step is boolean on/off. Ride tempo with /clock/tempo, lane volumes with the /kick_vol /snare_vol /hat_vol Good Buttons, and the overall tone with the /cutoff master-filter Good Button. Drums: kick = sine with a fast pitch-drop env; snare = noise + a tonal osc, both enveloped; hat = noise -> highpass filter -> short env.",
  "nodes": [
    {"type": "clock", "address": "/clock", "doc": "Shared timing. division=4 -> the gate pulses 4x per beat (a 16th-note grid).", "params": {"tempo": 120.0, "division": 4.0}, "control": {"label": "Tempo", "param": "tempo"}},
    {"type": "sequencer", "address": "/kick", "doc": "Kick lane: 16 boolean steps, every hit plays pitch degree 0.", "params": {"gate_mode": 1.0, "length": 16.0, "pitch": 0.0, "step1": 1.0, "step2": 0.0, "step3": 0.0, "step4": 0.0, "step5": 1.0, "step6": 0.0, "step7": 0.0, "step8": 0.0, "step9": 1.0, "step10": 0.0, "step11": 0.0, "step12": 0.0, "step13": 1.0, "step14": 0.0, "step15": 0.0, "step16": 0.0}, "control": [{"label": "K1", "param": "step1", "min": 0.0, "max": 1.0}, {"label": "K2", "param": "step2", "min": 0.0, "max": 1.0}, {"label": "K3", "param": "step3", "min": 0.0, "max": 1.0}, {"label": "K4", "param": "step4", "min": 0.0, "max": 1.0}, {"label": "K5", "param": "step5", "min": 0.0, "max": 1.0}, {"label": "K6", "param": "step6", "min": 0.0, "max": 1.0}, {"label": "K7", "param": "step7", "min": 0.0, "max": 1.0}, {"label": "K8", "param": "step8", "min": 0.0, "max": 1.0}, {"label": "K9", "param": "step9", "min": 0.0, "max": 1.0}, {"label": "K10", "param": "step10", "min": 0.0, "max": 1.0}, {"label": "K11", "param": "step11", "min": 0.0, "max": 1.0}, {"label": "K12", "param": "step12", "min": 0.0, "max": 1.0}, {"label": "K13", "param": "step13", "min": 0.0, "max": 1.0}, {"label": "K14", "param": "step14", "min": 0.0, "max": 1.0}, {"label": "K15", "param": "step15", "min": 0.0, "max": 1.0}, {"label": "K16", "param": "step16", "min": 0.0, "max": 1.0}]},
    {"type": "sequencer", "address": "/snare", "doc": "Snare lane: 16 boolean steps; backbeat on steps 5 and 13.", "params": {"gate_mode": 1.0, "length": 16.0, "pitch": 0.0, "step1": 0.0, "step2": 0.0, "step3": 0.0, "step4": 0.0, "step5": 1.0, "step6": 0.0, "step7": 0.0, "step8": 0.0, "step9": 0.0, "step10": 0.0, "step11": 0.0, "step12": 0.0, "step13": 1.0, "step14": 0.0, "step15": 0.0, "step16": 0.0}, "control": [{"label": "S1", "param": "step1", "min": 0.0, "max": 1.0}, {"label": "S2", "param": "step2", "min": 0.0, "max": 1.0}, {"label": "S3", "param": "step3", "min": 0.0, "max": 1.0}, {"label": "S4", "param": "step4", "min": 0.0, "max": 1.0}, {"label": "S5", "param": "step5", "min": 0.0, "max": 1.0}, {"label": "S6", "param": "step6", "min": 0.0, "max": 1.0}, {"label": "S7", "param": "step7", "min": 0.0, "max": 1.0}, {"label": "S8", "param": "step8", "min": 0.0, "max": 1.0}, {"label": "S9", "param": "step9", "min": 0.0, "max": 1.0}, {"label": "S10", "param": "step10", "min": 0.0, "max": 1.0}, {"label": "S11", "param": "step11", "min": 0.0, "max": 1.0}, {"label": "S12", "param": "step12", "min": 0.0, "max": 1.0}, {"label": "S13", "param": "step13", "min": 0.0, "max": 1.0}, {"label": "S14", "param": "step14", "min": 0.0, "max": 1.0}, {"label": "S15", "param": "step15", "min": 0.0, "max": 1.0}, {"label": "S16", "param": "step16", "min": 0.0, "max": 1.0}]},
    {"type": "sequencer", "address": "/hat", "doc": "Hat lane: 16 boolean steps; offbeat 8ths.", "params": {"gate_mode": 1.0, "length": 16.0, "pitch": 0.0, "step1": 1.0, "step2": 0.0, "step3": 1.0, "step4": 0.0, "step5": 1.0, "step6": 0.0, "step7": 1.0, "step8": 0.0, "step9": 1.0, "step10": 0.0, "step11": 1.0, "step12": 0.0, "step13": 1.0, "step14": 0.0, "step15": 1.0, "step16": 0.0}, "control": [{"label": "H1", "param": "step1", "min": 0.0, "max": 1.0}, {"label": "H2", "param": "step2", "min": 0.0, "max": 1.0}, {"label": "H3", "param": "step3", "min": 0.0, "max": 1.0}, {"label": "H4", "param": "step4", "min": 0.0, "max": 1.0}, {"label": "H5", "param": "step5", "min": 0.0, "max": 1.0}, {"label": "H6", "param": "step6", "min": 0.0, "max": 1.0}, {"label": "H7", "param": "step7", "min": 0.0, "max": 1.0}, {"label": "H8", "param": "step8", "min": 0.0, "max": 1.0}, {"label": "H9", "param": "step9", "min": 0.0, "max": 1.0}, {"label": "H10", "param": "step10", "min": 0.0, "max": 1.0}, {"label": "H11", "param": "step11", "min": 0.0, "max": 1.0}, {"label": "H12", "param": "step12", "min": 0.0, "max": 1.0}, {"label": "H13", "param": "step13", "min": 0.0, "max": 1.0}, {"label": "H14", "param": "step14", "min": 0.0, "max": 1.0}, {"label": "H15", "param": "step15", "min": 0.0, "max": 1.0}, {"label": "H16", "param": "step16", "min": 0.0, "max": 1.0}]},
    {"type": "voicer", "address": "/kick_v", "doc": "One-voice gate source for the kick.", "params": {"voices": 1}},
    {"type": "voicer", "address": "/snare_v", "doc": "One-voice gate source for the snare.", "params": {"voices": 1}},
    {"type": "voicer", "address": "/hat_v", "doc": "One-voice gate source for the hat.", "params": {"voices": 1}},
    {"type": "m2s", "address": "/kick_sweep_amt", "doc": "Constant pitch-sweep amount (Hz) for the kick pitch-drop.", "params": {"mode": 0.0, "default": 220.0}},
    {"type": "envelope", "address": "/kick_penv", "doc": "Pitch-drop envelope generator -> linear CV, very fast decay -> the kick 'thump'.", "params": {"attack": 0.001, "decay": 0.06, "sustain": 0.0, "release": 0.06}},
    {"type": "mul", "address": "/kick_penv_vca", "doc": "Scale the sweep amount by the (linear) pitch envelope CV."},
    {"type": "m2s", "address": "/kick_base", "doc": "Constant kick base frequency (Hz).", "params": {"mode": 0.0, "default": 48.0}},
    {"type": "add", "address": "/kick_freq", "doc": "kick freq = base (a) + decaying sweep (b)."},
    {"type": "oscillator", "address": "/kick_osc", "doc": "Sine body, frequency driven by the pitch-drop.", "params": {"waveform": 0.0}},
    {"type": "envelope", "address": "/kick_aenv", "doc": "Amplitude envelope generator -> linear CV, fast decay.", "params": {"attack": 0.001, "decay": 0.12, "sustain": 0.0, "release": 0.08}},
    {"type": "power", "address": "/kick_aenv_curve", "doc": "Exponential-style volume curve (x^2) on the kick amp CV."},
    {"type": "mul", "address": "/kick_aenv_vca", "doc": "VCA: kick body * shaped amp CV."},
    {"type": "noise", "address": "/snare_noise", "doc": "Snare noise body."},
    {"type": "envelope", "address": "/snare_nenv", "doc": "Noise amplitude envelope generator -> linear CV, short snap.", "params": {"attack": 0.001, "decay": 0.09, "sustain": 0.0, "release": 0.06}},
    {"type": "power", "address": "/snare_nenv_curve", "doc": "Exponential-style volume curve (x^2) on the snare-noise CV."},
    {"type": "mul", "address": "/snare_nenv_vca", "doc": "VCA: snare noise * shaped amp CV."},
    {"type": "m2s", "address": "/snare_tone_f", "doc": "Constant tonal frequency (Hz) for the snare's ring.", "params": {"mode": 0.0, "default": 185.0}},
    {"type": "oscillator", "address": "/snare_osc", "doc": "Tonal component (sine) under the noise.", "params": {"waveform": 0.0}},
    {"type": "envelope", "address": "/snare_tenv", "doc": "Tonal amplitude envelope generator -> linear CV, very short.", "params": {"attack": 0.001, "decay": 0.05, "sustain": 0.0, "release": 0.04}},
    {"type": "power", "address": "/snare_tenv_curve", "doc": "Exponential-style volume curve (x^2) on the snare-tone CV."},
    {"type": "mul", "address": "/snare_tenv_vca", "doc": "VCA: snare tone * shaped amp CV."},
    {"type": "add", "address": "/snare_mix", "doc": "snare = noise body (a) + tonal ring (b)."},
    {"type": "noise", "address": "/hat_noise", "doc": "Hat noise source."},
    {"type": "filter", "address": "/hat_hp", "doc": "Highpass (mode=1) to thin the noise into a metallic hat.", "params": {"mode": 1.0, "cutoff": 7000.0, "resonance": 0.1}},
    {"type": "envelope", "address": "/hat_env", "doc": "Very short amplitude envelope generator -> linear CV -> tick.", "params": {"attack": 0.001, "decay": 0.04, "sustain": 0.0, "release": 0.03}},
    {"type": "power", "address": "/hat_env_curve", "doc": "Exponential-style volume curve (x^2) on the hat CV."},
    {"type": "mul", "address": "/hat_env_vca", "doc": "VCA: hat noise * shaped amp CV."},
    {"type": "map", "address": "/kick_vol", "doc": "Kick lane volume Good Button [0,1].", "params": {"default": 0.7}, "control": {"label": "Kick Vol", "widget": "fader"}},
    {"type": "m2s", "address": "/kick_vol_cv", "doc": "Smooth kick volume into a constant CV.", "params": {"mode": 2.0, "time": 0.02, "default": 0.7}},
    {"type": "mul", "address": "/kick_amp", "doc": "kick audio * volume CV."},
    {"type": "map", "address": "/snare_vol", "doc": "Snare lane volume Good Button [0,1].", "params": {"default": 0.5}, "control": {"label": "Snare Vol", "widget": "fader"}},
    {"type": "m2s", "address": "/snare_vol_cv", "doc": "Smooth snare volume into a constant CV.", "params": {"mode": 2.0, "time": 0.02, "default": 0.5}},
    {"type": "mul", "address": "/snare_amp", "doc": "snare audio * volume CV."},
    {"type": "map", "address": "/hat_vol", "doc": "Hat lane volume Good Button [0,1].", "params": {"default": 0.35}, "control": {"label": "Hat Vol", "widget": "fader"}},
    {"type": "m2s", "address": "/hat_vol_cv", "doc": "Smooth hat volume into a constant CV.", "params": {"mode": 2.0, "time": 0.02, "default": 0.35}},
    {"type": "mul", "address": "/hat_amp", "doc": "hat audio * volume CV."},
    {"type": "add", "address": "/mix_a", "doc": "kick (a) + snare (b)."},
    {"type": "add", "address": "/mix", "doc": "(kick+snare) (a) + hat (b) -> full drum mix."},
    {"type": "filter", "address": "/master", "doc": "Master lowpass (mode=0); cutoff is a Good Button to tone the whole kit."},
    {"type": "m2s", "address": "/trim_cv", "doc": "Constant master trim (headroom so overlapping hits don't clip).", "params": {"mode": 0.0, "default": 0.7}},
    {"type": "mul", "address": "/trim", "doc": "master audio * trim CV -> headroom."},
    {"type": "output", "address": "/out"},
    {"type": "map", "address": "/cutoff", "doc": "PUBLIC master-filter Good Button: brightness [0,1] -> cutoff. Rests at 0.8.", "params": {"out_min": 500.0, "out_max": 16000.0, "curve": 1.0, "default": 0.8}, "control": {"label": "Tone", "widget": "fader"}},
    {"type": "m2s", "address": "/cutoff_cv", "doc": "Smooth the master cutoff into a CV.", "params": {"mode": 2.0, "time": 0.03, "default": 13000.0}}
  ],
  "connections": [
    {"from": {"node": "/clock", "port": "gate"}, "to": {"node": "/kick", "port": "clock"}},
    {"from": {"node": "/clock", "port": "gate"}, "to": {"node": "/snare", "port": "clock"}},
    {"from": {"node": "/clock", "port": "gate"}, "to": {"node": "/hat", "port": "clock"}},
    {"from": {"node": "/kick", "port": "degrees"}, "to": {"node": "/kick_v", "port": "notes"}},
    {"from": {"node": "/snare", "port": "degrees"}, "to": {"node": "/snare_v", "port": "notes"}},
    {"from": {"node": "/hat", "port": "degrees"}, "to": {"node": "/hat_v", "port": "notes"}},
    {"from": {"node": "/kick_sweep_amt", "port": "out"}, "to": {"node": "/kick_penv_vca", "port": "a"}},
    {"from": {"node": "/kick_penv", "port": "cv"}, "to": {"node": "/kick_penv_vca", "port": "b"}},
