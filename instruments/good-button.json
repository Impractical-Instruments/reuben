{
  "doc": "A playable saw synth with one 'brightness' Good Button (ADR-0017). Send /voicer/note [midi, gate] to play, then sweep /brightness [0..1] — a single knob fanned to filter cutoff AND resonance, each over its own musical range, smoothed into the audio rate. Built entirely from composition: a public identity `map` fanned to two ranged `map`s, each through an `m2s` converter into the filter's Signal cutoff/resonance inputs. No new instrument-format machinery.",
  "instrument": "good-button",
  "nodes": [
    {
      "address": "/voicer",
      "config": {
        "voices": 8
      },
      "control": {
        "label": "Play C",
        "note": 60,
        "port": "note",
        "widget": "note-toggle"
      },
      "doc": "Note -> per-Voice freq + gate.",
      "type": "voicer"
    },
    {
      "address": "/osc",
      "doc": "Saw tone (harmonics for the filter to chew).",
      "inputs": {
        "freq": {
          "from": "/voicer.freq"
        },
        "waveform": "Saw"
      },
      "type": "oscillator"
    },
    {
      "address": "/filter",
      "doc": "Cutoff + resonance are Signal inputs, driven by the Good Button.",
      "inputs": {
        "audio": {
          "from": "/osc"
        },
        "cutoff": {
          "from": "/cv_cutoff"
        },
        "resonance": {
          "from": "/cv_res"
        }
      },
      "type": "filter"
    },
    {
      "address": "/env",
      "control": [
        {
          "label": "Attack",
          "param": "attack"
        },
        {
          "label": "Decay",
          "param": "decay"
        },
        {
          "label": "Sustain",
          "param": "sustain"
        },
        {
          "label": "Release",
          "param": "release"
        }
      ],
      "doc": "ADSR envelope (linear CV), gated by the voicer.",
      "inputs": {
        "gate": {
          "from": "/voicer.gate"
        }
      },
      "type": "envelope"
    },
    {
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env"
        }
      },
      "type": "power"
    },
    {
      "address": "/env_vca",
      "doc": "VCA: audio * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/filter"
        },
        "b": {
          "from": "/env_curve"
        }
      },
      "type": "mul"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      },
      "type": "output"
    },
    {
      "address": "/brightness",
      "control": {
        "label": "Brightness",
        "widget": "fader"
      },
      "doc": "PUBLIC Good Button. Identity [0,1] pass-through; its value is fanned to the two ranged maps below. Send /brightness [0..1]. Rests at 0.5 (ADR-0018), emitted on init so the chain and any generated control surface agree at rest.",
      "inputs": {
        "default": 0.5
      },
      "type": "map"
    },
    {
      "address": "/map_cutoff",
      "doc": "brightness [0,1] -> cutoff [400,12000] Hz, exponential (perceptually even).",
      "inputs": {
        "curve": "Exponential",
        "in": {
          "from": "/brightness"
        },
        "out_max": 12000.0,
        "out_min": 400.0
      },
      "type": "map"
    },
    {
      "address": "/map_res",
      "doc": "brightness [0,1] -> resonance [0.1,0.85], linear.",
      "inputs": {
        "in": {
          "from": "/brightness"
        },
        "out_max": 0.85,
        "out_min": 0.1
      },
      "type": "map"
    },
    {
      "address": "/cv_cutoff",
      "doc": "Smooth the mapped cutoff into a CV signal; default 2500 Hz before any knob move.",
      "inputs": {
        "default": 2500.0,
        "in": {
          "from": "/map_cutoff"
        },
        "mode": "Smooth",
        "time": 0.03
      },
      "type": "m2s"
    },
    {
      "address": "/cv_res",
      "doc": "Smooth the mapped resonance into a CV signal; default 0.3.",
      "inputs": {
        "default": 0.3,
        "in": {
          "from": "/map_res"
        },
        "mode": "Smooth",
        "time": 0.03
      },
      "type": "m2s"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
