{
  "doc": "Monophonic playable rig with a mono Freeverb in the master path. Send /voicer/note [midi, gate] to play (e.g. [69.0, 1.0] note-on A4, [69.0, 0.0] note-off). Shape the space live over OSC: /reverb/room (tail length 0..1), /reverb/damp (high-frequency damping 0..1), /reverb/mix (dry/wet 0..1).",
  "instrument": "reverb",
  "nodes": [
    {
      "address": "/voicer",
      "config": {
        "voices": 8
      },
      "doc": "Note -> per-Voice freq + gate CV.",
      "type": "voicer"
    },
    {
      "address": "/osc",
      "inputs": {
        "freq": {
          "from": "/voicer.freq"
        }
      },
      "type": "oscillator"
    },
    {
      "address": "/filter",
      "doc": "Gentle lowpass.",
      "inputs": {
        "audio": {
          "from": "/osc"
        },
        "cutoff": 3000.0
      },
      "type": "filter"
    },
    {
      "address": "/env",
      "doc": "ADSR envelope (linear CV), gated by the voicer.",
      "inputs": {
        "gate": {
          "from": "/voicer.gate"
        }
      },
      "type": "envelope"
    },
    {
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env"
        }
      },
      "type": "power"
    },
    {
      "address": "/env_vca",
      "doc": "VCA: audio * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/filter"
        },
        "b": {
          "from": "/env_curve"
        }
      },
      "type": "mul"
    },
    {
      "address": "/reverb",
      "doc": "Mono Freeverb on the master bus.",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        },
        "damp": 0.5,
        "mix": 0.3,
        "room": 0.7
      },
      "type": "reverb"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/reverb"
        }
      },
      "type": "output"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
