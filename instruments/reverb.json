{
  "instrument": "reverb",
  "doc": "Monophonic playable rig with a mono Freeverb in the master path. Send /voicer/note [midi, gate] to play (e.g. [69.0, 1.0] note-on A4, [69.0, 0.0] note-off). Shape the space live over OSC: /reverb/room (tail length 0..1), /reverb/damp (high-frequency damping 0..1), /reverb/mix (dry/wet 0..1).",
  "nodes": [
    { "type": "voicer", "address": "/voicer", "doc": "Note -> per-Voice freq + gate CV.", "params": { "voices": 8 } },
    { "type": "oscillator", "address": "/osc" },
    { "type": "filter", "address": "/filter", "doc": "Gentle lowpass.", "params": { "cutoff": 3000.0 } },
    { "type": "envelope", "address": "/env", "doc": "ADSR VCA, gated by the voicer." },
    { "type": "reverb", "address": "/reverb", "doc": "Mono Freeverb on the master bus.", "params": { "room": 0.7, "damp": 0.5, "mix": 0.3 } },
    { "type": "output", "address": "/out" }
  ],
  "connections": [
    { "from": { "node": "/voicer", "port": "freq" }, "to": { "node": "/osc", "port": "freq" } },
    { "from": { "node": "/osc", "port": "audio" }, "to": { "node": "/filter", "port": "audio" } },
    { "from": { "node": "/filter", "port": "audio" }, "to": { "node": "/env", "port": "audio" } },
    { "from": { "node": "/voicer", "port": "gate" }, "to": { "node": "/env", "port": "gate" } },
    { "from": { "node": "/env", "port": "audio" }, "to": { "node": "/reverb", "port": "audio" } },
    { "from": { "node": "/reverb", "port": "audio" }, "to": { "node": "/out", "port": "audio" } }
  ],
  "outputs": [
    { "node": "/out", "port": "audio" }
  ]
}
