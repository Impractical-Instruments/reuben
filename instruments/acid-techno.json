      "type": "m2s",
      "address": "/chh_trim",
      "doc": "Baked relative level for the chh lane in the kit balance.",
      "inputs": {
        "in": 0.4,
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/chh_amp",
      "doc": "chh audio * lane trim.",
      "inputs": {
        "a": {
          "from": "/chh_v.audio"
        },
        "b": {
          "from": "/chh_trim"
        }
      }
    },
    {
      "type": "sequencer",
      "address": "/ohh",
      "doc": "ohh lane: 16 boolean gate steps.",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "gate_mode": "Gate",
        "length": 16.0,
        "pitch": 0.0,
        "step1": {
          "from": "/ohh_step1"
        },
        "step2": {
          "from": "/ohh_step2"
        },
        "step3": {
          "from": "/ohh_step3"
        },
        "step4": {
          "from": "/ohh_step4"
        },
        "step5": {
          "from": "/ohh_step5"
        },
        "step6": {
          "from": "/ohh_step6"
        },
        "step7": {
          "from": "/ohh_step7"
        },
        "step8": {
          "from": "/ohh_step8"
        },
        "step9": {
          "from": "/ohh_step9"
        },
        "step10": {
          "from": "/ohh_step10"
        },
        "step11": {
          "from": "/ohh_step11"
        },
        "step12": {
          "from": "/ohh_step12"
        },
        "step13": {
          "from": "/ohh_step13"
        },
        "step14": {
          "from": "/ohh_step14"
        },
        "step15": {
          "from": "/ohh_step15"
        },
        "step16": {
          "from": "/ohh_step16"
        }
      }
    },
    {
      "type": "voicer",
      "address": "/ohh_v",
      "doc": "Hosts the openhat-voice; the lane gate fires it.",
      "config": {
        "voices": 1.0
      },
      "inputs": {
        "notes": {
          "from": "/ohh"
        }
      },
      "voice": "openhat-voice"
    },
    {
      "type": "m2s",
      "address": "/ohh_trim",
      "doc": "Baked relative level for the ohh lane in the kit balance.",
      "inputs": {
        "in": 0.4,
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/ohh_amp",
      "doc": "ohh audio * lane trim.",
      "inputs": {
        "a": {
          "from": "/ohh_v.audio"
        },
        "b": {
          "from": "/ohh_trim"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/dsum1",
      "doc": "kick + snare.",
      "inputs": {
        "a": {
          "from": "/kick_amp"
        },
        "b": {
          "from": "/snare_amp"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/dsum2",
      "doc": "+ closed hat.",
      "inputs": {
        "a": {
          "from": "/dsum1"
        },
        "b": {
          "from": "/chh_amp"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/dsum3",
      "doc": "+ open hat -> full kit.",
      "inputs": {
        "a": {
          "from": "/dsum2"
        },
        "b": {
          "from": "/ohh_amp"
        }
      }
    },
    {
      "type": "saturator",
      "address": "/dsat",
      "doc": "Warm tanh glue on the kit; peak-normalized so overlapping hits squash instead of clipping.",
      "inputs": {
        "audio": {
          "from": "/dsum3"
        },
        "drive": 2.5,
        "warmth": 0.5
      }
    },
    {
      "type": "m2s",
      "address": "/drums_vol_cv",
      "doc": "Smooth the drums_vol pipe into a CV.",
      "inputs": {
        "in": {
          "from": "/drums_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/drums_out",
      "doc": "kit * drums volume.",
      "inputs": {
        "a": {
          "from": "/dsat"
        },
        "b": {
          "from": "/drums_vol_cv"
        }
      }
    },
    {
      "type": "harmony",
      "address": "/bass_harmony",
      "doc": "Tonal context for the bass (natural minor). KEY/CHORD SELECTOR: the `key` pipe (/key/in) sets `root`; the whole bass line and the pad re-spell live when it changes.",
      "inputs": {
        "root": {
          "from": "/key"
        },
        "degrees": 7.0,
        "s0": 0.0,
        "s1": 2.0,
        "s2": 3.0,
        "s3": 5.0,
        "s4": 7.0,
        "s5": 8.0,
        "s6": 10.0
      }
    },
    {
      "type": "add_f32_value",
      "address": "/key_up",
      "doc": "Pad root = key + 12 (one octave up) so the pad sits above the bass.",
      "inputs": {
        "a": {
          "from": "/key"
        },
        "b": 12.0
      }
    },
    {
      "type": "harmony",
      "address": "/pad_harmony",
      "doc": "Tonal context for the pad (same natural minor, one octave up). Re-spells with /key.",
      "inputs": {
        "root": {
          "from": "/key_up"
        },
        "degrees": 7.0,
        "s0": 0.0,
        "s1": 2.0,
        "s2": 3.0,
        "s3": 5.0,
        "s4": 7.0,
        "s5": 8.0,
        "s6": 10.0
      }
    },
    {
      "type": "sequencer",
      "address": "/bass_seq",
      "doc": "TB-303 line: 16 degree steps (-1 = rest), resolved against /bass_harmony.",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "gate_mode": "Degree",
        "length": 16.0,
        "step1": {
          "from": "/bass_step1"
        },
        "step2": {
          "from": "/bass_step2"
        },
        "step3": {
          "from": "/bass_step3"
        },
        "step4": {
          "from": "/bass_step4"
        },
        "step5": {
          "from": "/bass_step5"
        },
        "step6": {
          "from": "/bass_step6"
        },
        "step7": {
          "from": "/bass_step7"
        },
        "step8": {
          "from": "/bass_step8"
        },
        "step9": {
          "from": "/bass_step9"
        },
        "step10": {
          "from": "/bass_step10"
        },
        "step11": {
          "from": "/bass_step11"
        },
        "step12": {
          "from": "/bass_step12"
        },
        "step13": {
          "from": "/bass_step13"
        },
        "step14": {
          "from": "/bass_step14"
        },
        "step15": {
          "from": "/bass_step15"
        },
        "step16": {
          "from": "/bass_step16"
        }
      }
    },
    {
      "type": "transpose",
      "address": "/bass_mode",
      "doc": "MODE SELECTOR (bass): shift every bass degree by the `mode` pipe (/mode/in, 0-6 scale steps), re-centering the whole line on that degree -- modal, staying in the current key's collection. amount=0 leaves the line on the tonic.",
      "inputs": {
        "notes": {
          "from": "/bass_seq"
        },
        "amount": {
          "from": "/mode"
        }
      }
    },
    {
      "type": "unpack_note",
      "address": "/bass_unpack",
      "doc": "Unbundle the mono bass note line into held fields (ADR-0063): `pitch` (the degree, a vocab Pitch) feeds pitch2freq; `velocity` (1 = note-on, 0 = note-off) IS the mono synth's gate. This replaces the voicer -- inlining the 303 synth at rig level so its glide/filter/resonance params can be driven by interface pipes (the voicer only forwards freq/gate).",
      "inputs": {
        "in": {
          "from": "/bass_mode"
        }
      }
    },
    {
      "type": "pitch2freq",
      "address": "/bass_freq",
      "doc": "Resolve the mode-shifted degree to Hz against /bass_harmony (natural minor) -- the note→freq step the voicer used to do internally (ADR-0064).",
      "inputs": {
        "pitch": {
          "from": "/bass_unpack.pitch"
        },
        "harmony": {
          "from": "/bass_harmony"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/bass_glide",
      "doc": "PITCH GLIDE (303 slide): portamento the note freq toward each new target over `time` seconds, set by the /glide pipe (/glide/in, 0 = instant jumps). Value freq -> glided Signal into the oscillator.",
      "inputs": {
        "in": {
          "from": "/bass_freq.freq"
        },
        "mode": "Glide",
        "time": {
          "from": "/glide"
        }
      }
    },
    {
      "type": "oscillator",
      "address": "/bass_osc",
      "doc": "Saw core -- rich harmonics for the resonant filter to carve. Freq rides the glide.",
      "inputs": {
        "freq": {
          "from": "/bass_glide"
        },
        "waveform": "Saw"
      }
    },
    {
      "type": "envelope",
      "address": "/bass_env",
      "doc": "Snappy 303 contour: fast attack, low sustain. Gate is the unpacked note velocity; `decay` is the /filter_decay pipe (/filter_decay/in) -- longer decay = longer squelch tail. Drives BOTH the filter sweep and the VCA.",
      "inputs": {
        "gate": {
          "from": "/bass_unpack.velocity"
        },
        "attack": 0.005,
        "decay": {
          "from": "/filter_decay"
        },
        "sustain": 0.25,
        "release": 0.09
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/bass_env_amt",
      "doc": "FILTER ENV AMOUNT: scale the env CV by the /filter_env pipe (/filter_env/in) before it maps to cutoff. 1 = full sweep to 2800 Hz; 0 = filter stays parked at the 160 Hz floor (no squelch).",
      "inputs": {
        "a": {
          "from": "/bass_env.cv"
        },
        "b": {
          "from": "/filter_env"
        }
      }
    },
    {
      "type": "map_f32_signal",
      "address": "/bass_cutoff",
      "doc": "Amount-scaled env CV [0,1] -> filter cutoff [160,2800] Hz (exponential). The acid squelch: the filter opens on the attack and closes as the note decays; env amount sets how far it opens.",
      "inputs": {
        "in": {
          "from": "/bass_env_amt"
        },
        "out_min": 160.0,
        "out_max": 2800.0,
        "curve": "Exponential"
      }
    },
    {
      "type": "filter",
      "address": "/bass_filter",
      "doc": "Resonant lowpass -- cutoff rides the env sweep; `resonance` is the /squelch pipe (/squelch/in), the whistling acid-tone control.",
      "inputs": {
        "audio": {
          "from": "/bass_osc"
        },
        "cutoff": {
          "from": "/bass_cutoff"
        },
        "mode": "Lp",
        "resonance": {
          "from": "/squelch"
        }
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/bass_ampcurve",
      "doc": "Shape the linear env CV into an x-squared perceptual volume curve for the VCA.",
      "inputs": {
        "x": {
          "from": "/bass_env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/bass_vca",
      "doc": "VCA: filtered saw (a) * shaped amp CV (b) -- the mono synth's audio output.",
      "inputs": {
        "a": {
          "from": "/bass_filter"
        },
        "b": {
          "from": "/bass_ampcurve"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/bass_vol_cv",
      "doc": "Smooth the bass_vol pipe into a CV.",
      "inputs": {
        "in": {
          "from": "/bass_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/bass_out",
      "doc": "bass * bass volume.",
      "inputs": {
        "a": {
          "from": "/bass_vca"
        },
        "b": {
          "from": "/bass_vol_cv"
        }
      }
    },
    {
      "type": "sequencer",
      "address": "/pad_seq",
      "doc": "Whole-note trigger: length-4 on the beat clock, degree 0 on the downbeat, rests elsewhere -> one chord root per bar.",
      "inputs": {
        "clock": {
          "from": "/pad_clock.gate"
        },
        "gate_mode": "Degree",
        "length": 4.0,
        "step1": 0.0,
        "step2": -1.0,
        "step3": -1.0,
        "step4": -1.0
      }
    },
    {
      "type": "transpose",
      "address": "/pad_mode",
      "doc": "MODE SELECTOR (pad): shift the whole-note trigger degree by the SAME `mode` pipe (/mode/in) so the pad chord roots on the selected degree, moving in lockstep with the bass -- one knob re-roots both.",
      "inputs": {
        "notes": {
          "from": "/pad_seq"
        },
        "amount": {
          "from": "/mode"
        }
      }
    },
    {
      "type": "chord",
      "address": "/pad_chord",
      "doc": "Stacks scale-relative thirds on the mode-shifted degree -> triad `degree` notes; the voicer resolves them through /pad_harmony so the chord re-spells on /key change and re-roots on /mode change.",
      "inputs": {
        "set": {
          "from": "/pad_mode"
        },
        "size": 3.0
      }
    },
    {
      "type": "voicer",
      "address": "/pad_v",
      "doc": "8-voice detuned pad; chord degrees resolve through /pad_harmony. 8 voices let long-release whole-note chords overlap.",
      "config": {
        "voices": 8.0
      },
      "inputs": {
        "notes": {
          "from": "/pad_chord"
        },
        "harmony": {
          "from": "/pad_harmony"
        }
      },
      "voice": "acid-pad-voice"
    },
    {
      "type": "m2s",
      "address": "/pad_vol_cv",
      "doc": "Smooth the pad_vol pipe into a CV.",
      "inputs": {
        "in": {
          "from": "/pad_vol"
        },
        "mode": "Smooth",
        "time": 0.02
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/pad_out",
      "doc": "pad * pad volume.",
      "inputs": {
        "a": {
          "from": "/pad_v.audio"
        },
        "b": {
          "from": "/pad_vol_cv"
        }
      }
    },
    {
      "type": "compressor",
      "address": "/pad_pump",
      "doc": "Sidechain pump: ducks the pad (`audio` <- /pad_out) in time with the kick (`sidechain` <- /kick_v.audio, the raw kick voicer before the drum trim). Every four-on-the-floor kick shoves the pad down and it ramps back over the release — the classic acid-techno breathing pad. Low threshold + fast attack so each kick fully triggers a snappy duck; ~200 ms release recovers before the next quarter-note kick. key_hp stays open (20 Hz) so the kick's low end drives the detector rather than being filtered out; makeup 0 so the duck reads as a real level drop.",
      "inputs": {
        "audio": {
          "from": "/pad_out"
        },
        "sidechain": {
          "from": "/kick_v.audio"
        },
        "threshold": -30.0,
        "ratio": 5.0,
        "attack": 1.0,
        "release": 200.0,
        "makeup": 0.0,
        "key_hp": 20.0
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix1",
      "doc": "drums + bass.",
      "inputs": {
        "a": {
          "from": "/drums_out"
        },
        "b": {
          "from": "/bass_out"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix2",
      "doc": "+ pumped pad -> full mix.",
      "inputs": {
        "a": {
          "from": "/mix1"
        },
        "b": {
          "from": "/pad_pump.audio"
        }
      }
    },
    {
      "type": "reverb",
      "address": "/master_verb",
      "doc": "Big-room reverb on the full mix, low wet mix -- a wide ambient tail behind the whole rig without washing out the four-on-the-floor. Sits before the master saturator so the glue catches the tail too.",
      "inputs": {
        "audio": {
          "from": "/mix2"
        },
        "room": 0.9,
        "damp": 0.5,
        "mix": 0.15
      }
    },
    {
      "type": "saturator",
      "address": "/master_sat",
      "doc": "Gentle master glue / soft ceiling so all three instruments together stay off the clip line.",
      "inputs": {
        "audio": {
          "from": "/master_verb.audio"
        },
        "drive": 1.4,
        "warmth": 0.3
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/master_sat"
        }
      }
    }
  ]
}
