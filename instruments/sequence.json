{
  "instrument": "sequence",
  "doc": "A self-playing 8-step melody. The Clock's beat gate drives a sequencer that walks a pattern of pitches (a C-major scale by default), one note per beat, into an oscillator + envelope. Set tempo via /clock/tempo; edit the line via /sequencer/step1../sequencer/step8 (MIDI note, below 0 = rest) and /sequencer/length; send /clock/reset to relocate beat 1.",
  "nodes": [
    { "type": "clock", "address": "/clock", "doc": "Beat phasor + beat gate.", "params": { "tempo": 120.0 } },
    { "type": "sequencer", "address": "/sequencer", "doc": "Walks the pattern one step per beat -> freq + gate CV." },
    { "type": "oscillator", "address": "/osc" },
    { "type": "filter", "address": "/filter", "doc": "Gentle lowpass.", "params": { "cutoff": 3000.0 } },
    { "type": "envelope", "address": "/env", "doc": "Plucked note, gated per step.", "params": { "attack": 0.005, "decay": 0.12, "sustain": 0.3, "release": 0.1 } },
    { "type": "output", "address": "/out" }
  ],
  "connections": [
    { "from": { "node": "/clock", "port": "gate" }, "to": { "node": "/sequencer", "port": "clock" } },
    { "from": { "node": "/sequencer", "port": "freq" }, "to": { "node": "/osc", "port": "freq" } },
    { "from": { "node": "/osc", "port": "audio" }, "to": { "node": "/filter", "port": "audio" } },
    { "from": { "node": "/filter", "port": "audio" }, "to": { "node": "/env", "port": "audio" } },
    { "from": { "node": "/sequencer", "port": "gate" }, "to": { "node": "/env", "port": "gate" } },
    { "from": { "node": "/env", "port": "audio" }, "to": { "node": "/out", "port": "audio" } }
  ],
  "outputs": [
    { "node": "/out", "port": "audio" }
  ]
}
