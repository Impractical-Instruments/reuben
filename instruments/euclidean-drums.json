{
  "format_version": 3,
  "instrument": "euclidean-drums",
  "doc": "A self-playing 4-channel Euclidean rhythm machine (kick, snare, tom, hat). One shared clock (division=4 -> a 16th-note grid) drives four `euclid` generators; each spreads its `pulses` hits evenly across `steps` (with `rotation` to shift the phase) and emits a gate that fires that channel's drum body. The bodies are seed-recipe references (ADR-0057), not inline node clusters: kick and tom are two references to voices/kick-voice.json (the pitch-drop body -- the tom overrides base/sweep/release: 130/120/0.12), snare is voices/snare-voice.json (noise + tonal ring), hat is voices/hat-voice.json (highpassed noise tick); every channel then runs through its own patches/dj-strip.json (DJ filter + level). Each body reference sets sustain 1.0 and wires its `decay` face pipe live, so the DECAY knobs behave exactly as the old inline channels did (on kick/tom decay stretches both the tail and the pitch sweep). Per channel you get: Euclidean controls (steps/pulses/rotation), a DECAY knob, a bipolar DJ FILTER knob (-1 lowpass down .. 0 open .. +1 highpass up), and a LEVEL knob. The four channels sum through a master trim to the output. Every knob is an interface input pipe (ADR-0043; presentation lives in surfaces/euclidean-drums.json): ride tempo via /tempo/in; reshape patterns via /<chan>_pulses/in, /<chan>_steps/in, /<chan>_rotation/in; sweep tone via /<chan>_filter/in [-1..1]; set loudness via /<chan>_level/in [0..1]; set tail via /<chan>_decay/in. The four <chan>_decay pipes declare default 0.001 rather than the retired inline literal 0.0: the loader coerce-clamped that literal to the envelope's range floor, so 0.001 IS the old effective rest value (a pipe default outside its declared range is a load error) — bit-identity vs the pre-v3 snapshot is asserted in format_v3_rewrite.rs, and vs the pre-recipe inline document in seed_recipes.rs.",
  "resources": {
    "dj-strip": "patches/dj-strip.json",
    "hat-voice": "voices/hat-voice.json",
    "kick-voice": "voices/kick-voice.json",
    "snare-voice": "voices/snare-voice.json"
  },
  "interface": {
    "inputs": {
      "tempo": {
        "type": "f32",
        "default": 120.0,
        "min": 1.0,
        "max": 999.0,
        "unit": "BPM"
      },
      "kick_pulses": {
        "type": "f32",
        "default": 4.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "kick_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "kick_rotation": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "kick_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "kick_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "kick_level": {
        "type": "f32",
        "default": 0.85,
        "min": 0.0,
        "max": 1.0
      },
      "snare_pulses": {
        "type": "f32",
        "default": 2.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "snare_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "snare_rotation": {
        "type": "f32",
        "default": 4.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "snare_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "snare_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "snare_level": {
        "type": "f32",
        "default": 0.6,
        "min": 0.0,
        "max": 1.0
      },
      "tom_pulses": {
        "type": "f32",
        "default": 3.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "tom_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "tom_rotation": {
        "type": "f32",
        "default": 2.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "tom_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "tom_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "tom_level": {
        "type": "f32",
        "default": 0.6,
        "min": 0.0,
        "max": 1.0
      },
      "hat_pulses": {
        "type": "f32",
        "default": 8.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "hat_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "hat_rotation": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "hat_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "hat_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "hat_level": {
        "type": "f32",
        "default": 0.5,
        "min": 0.0,
        "max": 1.0
      }
    },
    "outputs": {
      "out": {
        "from": "/out.audio"
      }
    }
  },
  "nodes": [
    {
      "type": "clock",
      "address": "/clock",
      "doc": "Shared timing. division=4 -> the gate pulses 4x per beat (a 16th-note grid) that clocks every euclid. tempo rides the /tempo pipe.",
      "inputs": {
        "division": 4.0,
        "tempo": {
          "from": "/tempo"
        }
      }
    },
    {
      "type": "euclid",
      "address": "/kick_eu",
      "doc": "Kick Euclidean generator. E(16,4,0) = four-on-the-floor (a pulse every 4 steps).",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": {
          "from": "/kick_pulses"
        },
        "rotation": {
          "from": "/kick_rotation"
        },
        "steps": {
          "from": "/kick_steps"
        }
      }
    },
    {
      "type": "subpatch",
      "address": "/kick_body",
      "doc": "Kick body: the pitch-drop drum recipe at its kick defaults (base 48, sweep 220), gated by the euclid pulse. sustain 1.0 + the live `decay` wire = the DECAY knob stretches tail AND pitch drop.",
      "inputs": {
        "decay": {
          "from": "/kick_decay"
        },
        "gate": {
          "from": "/kick_eu.gate"
        },
        "sustain": 1.0
      },
      "patch": "kick-voice"
    },
    {
      "type": "subpatch",
      "address": "/kick_strip",
      "doc": "Kick output stage: the DJ-filter + level strip, knobs on the /kick_filter and /kick_level pipes.",
      "inputs": {
        "audio": {
          "from": "/kick_body.audio"
        },
        "filter": {
          "from": "/kick_filter"
        },
        "level": {
          "from": "/kick_level"
        }
      },
      "patch": "dj-strip"
    },
    {
      "type": "euclid",
      "address": "/snare_eu",
      "doc": "Snare Euclidean generator. E(16,2,4) = the backbeat (steps 5 and 13).",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": {
          "from": "/snare_pulses"
        },
        "rotation": {
          "from": "/snare_rotation"
        },
        "steps": {
          "from": "/snare_steps"
        }
      }
    },
    {
      "type": "subpatch",
      "address": "/snare_body",
      "doc": "Snare body: the noise+tone recipe at its defaults (tone 185), gated by the euclid pulse; DECAY rides the live `decay` wire.",
      "inputs": {
        "decay": {
          "from": "/snare_decay"
        },
        "gate": {
          "from": "/snare_eu.gate"
        },
        "sustain": 1.0
      },
      "patch": "snare-voice"
    },
    {
      "type": "subpatch",
      "address": "/snare_strip",
      "doc": "Snare output stage: the DJ-filter + level strip, knobs on the /snare_filter and /snare_level pipes.",
      "inputs": {
        "audio": {
          "from": "/snare_body.audio"
        },
        "filter": {
          "from": "/snare_filter"
        },
        "level": {
          "from": "/snare_level"
        }
      },
      "patch": "dj-strip"
    },
    {
      "type": "euclid",
      "address": "/tom_eu",
      "doc": "Tom Euclidean generator. E(16,3,2) = three hits spread across the bar, shifted for a fill feel.",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": {
          "from": "/tom_pulses"
        },
        "rotation": {
          "from": "/tom_rotation"
        },
        "steps": {
          "from": "/tom_steps"
        }
      }
    },
    {
      "type": "subpatch",
      "address": "/tom_body",
      "doc": "Tom body: the same pitch-drop recipe as the kick (diamond reuse, ADR-0034), overridden boomier and higher -- base 130, gentler sweep 120, longer release 0.12.",
      "inputs": {
        "base": 130.0,
        "decay": {
          "from": "/tom_decay"
        },
        "gate": {
          "from": "/tom_eu.gate"
        },
        "release": 0.12,
        "sustain": 1.0,
        "sweep": 120.0
      },
      "patch": "kick-voice"
    },
    {
      "type": "subpatch",
      "address": "/tom_strip",
      "doc": "Tom output stage: the DJ-filter + level strip, knobs on the /tom_filter and /tom_level pipes.",
      "inputs": {
        "audio": {
          "from": "/tom_body.audio"
        },
        "filter": {
          "from": "/tom_filter"
        },
        "level": {
          "from": "/tom_level"
        }
      },
      "patch": "dj-strip"
    },
    {
      "type": "euclid",
      "address": "/hat_eu",
      "doc": "Hat Euclidean generator. E(16,8,0) = straight offbeat 8ths (every other step).",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": {
          "from": "/hat_pulses"
        },
        "rotation": {
          "from": "/hat_rotation"
        },
        "steps": {
          "from": "/hat_steps"
        }
      }
    },
    {
      "type": "subpatch",
      "address": "/hat_body",
      "doc": "Hat body: the highpassed-noise-tick recipe at its defaults (cutoff 7000), gated by the euclid pulse; DECAY rides the live `decay` wire (short tick .. open hat).",
      "inputs": {
        "decay": {
          "from": "/hat_decay"
        },
        "gate": {
          "from": "/hat_eu.gate"
        },
        "sustain": 1.0
      },
      "patch": "hat-voice"
    },
    {
      "type": "subpatch",
      "address": "/hat_strip",
      "doc": "Hat output stage: the DJ-filter + level strip, knobs on the /hat_filter and /hat_level pipes.",
      "inputs": {
        "audio": {
          "from": "/hat_body.audio"
        },
        "filter": {
          "from": "/hat_filter"
        },
        "level": {
          "from": "/hat_level"
        }
      },
      "patch": "dj-strip"
    },
    {
      "type": "add_f32_signal",
      "address": "/mix_a",
      "doc": "kick + snare.",
      "inputs": {
        "a": {
          "from": "/kick_strip.audio"
        },
        "b": {
          "from": "/snare_strip.audio"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix_b",
      "doc": "tom + hat.",
      "inputs": {
        "a": {
          "from": "/tom_strip.audio"
        },
        "b": {
          "from": "/hat_strip.audio"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix",
      "doc": "(kick+snare) + (tom+hat) -> full kit mix.",
      "inputs": {
        "a": {
          "from": "/mix_a"
        },
        "b": {
          "from": "/mix_b"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/trim_cv",
      "doc": "Constant master trim (headroom so overlapping hits don't clip).",
      "inputs": {
        "in": 0.7
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/trim",
      "doc": "master audio * trim CV -> headroom.",
      "inputs": {
        "a": {
          "from": "/mix"
        },
        "b": {
          "from": "/trim_cv"
        }
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/trim"
        }
      }
    }
  ]
}
