{
  "doc": "Play any pitch; hear the nearest scale tone. External absolute notes at /snap/notes [midi, vel] are quantized to the tonal context by a snap operator, which emits scale degrees into the Voicer (the 'always in key' good-button). Set the key/scale on /harmony/root, /harmony/s0../harmony/s6, /harmony/degrees; set snap behaviour with /snap/target (0 Scale, 1 Chord, 2 ChordThenScale) and /snap/direction (0 Nearest, 1 Up, 2 Down). Both the snap and the Voicer read the same context, so changing key re-tunes held notes live.",
  "instrument": "autotune",
  "nodes": [
    {
      "address": "/harmony",
      "doc": "C major, 12-TET (default scale).",
      "type": "harmony"
    },
    {
      "address": "/snap",
      "doc": "Absolute note -> nearest in-scale degree.",
      "inputs": {
        "harmony": {
          "from": "/harmony"
        }
      },
      "type": "snap"
    },
    {
      "address": "/voicer",
      "config": {
        "voices": 6
      },
      "doc": "Degrees -> Hz via the tonal context.",
      "inputs": {
        "harmony": {
          "from": "/harmony"
        },
        "notes": {
          "from": "/snap"
        }
      },
      "type": "voicer"
    },
    {
      "address": "/osc",
      "inputs": {
        "freq": {
          "from": "/voicer.freq"
        }
      },
      "type": "oscillator"
    },
    {
      "address": "/filter",
      "inputs": {
        "audio": {
          "from": "/osc"
        },
        "cutoff": 3000.0
      },
      "type": "filter"
    },
    {
      "address": "/env",
      "inputs": {
        "attack": 0.01,
        "decay": 0.2,
        "gate": {
          "from": "/voicer.gate"
        },
        "release": 0.2,
        "sustain": 0.6
      },
      "type": "envelope"
    },
    {
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/env_vca",
      "doc": "VCA: audio * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/filter"
        },
        "b": {
          "from": "/env_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      },
      "type": "output"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
