{
  "doc": "A click on every beat. The Clock's beat gate retriggers an envelope on an 880 Hz tone — sample-accurate timing with no external input. Send /clock/sync to relocate beat 1; set tempo via /clock/tempo.",
  "instrument": "metronome",
  "nodes": [
    {
      "address": "/clock",
      "doc": "Beat phasor + beat gate.",
      "inputs": {
        "tempo": 120.0
      },
      "type": "clock"
    },
    {
      "address": "/osc",
      "doc": "Fixed click tone.",
      "inputs": {
        "freq": 880.0
      },
      "type": "oscillator"
    },
    {
      "address": "/env",
      "doc": "Plucked click, gated by the beat.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.05,
        "gate": {
          "from": "/clock.gate"
        },
        "release": 0.05,
        "sustain": 0.0
      },
      "type": "envelope"
    },
    {
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/env_vca",
      "doc": "VCA: audio * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/osc"
        },
        "b": {
          "from": "/env_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      },
      "type": "output"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
