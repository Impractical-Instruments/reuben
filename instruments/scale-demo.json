{
  "doc": "The same self-playing sequence as sequence.json, but the Voicer resolves each step degree through a tonal context set to C natural minor — so the identical degree pattern (0..7) re-spells into the minor scale with no edit to the line. Change the key live with /harmony/root (MIDI), or reshape the scale with /harmony/s0../harmony/s6 (step offsets) and /harmony/degrees; both apply sample-accurately. Send a chord with /harmony/set [tag, d0, d1, ...] (tag 1 = scale-relative, 2 = absolute, 0 = clear).",
  "instrument": "scale-demo",
  "nodes": [
    {
      "address": "/clock",
      "inputs": {
        "tempo": 110.0
      },
      "type": "clock"
    },
    {
      "address": "/sequencer",
      "doc": "Default ascending pattern, degrees 0..7.",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        }
      },
      "type": "sequencer"
    },
    {
      "address": "/harmony",
      "doc": "C natural minor, 12-TET.",
      "inputs": {
        "degrees": 7.0,
        "root": 60.0,
        "s0": 0.0,
        "s1": 2.0,
        "s2": 3.0,
        "s3": 5.0,
        "s4": 7.0,
        "s5": 8.0,
        "s6": 10.0
      },
      "type": "harmony"
    },
    {
      "address": "/voicer",
      "config": {
        "voices": 4
      },
      "doc": "Degrees -> Hz via the tonal context.",
      "inputs": {
        "harmony": {
          "from": "/harmony"
        },
        "notes": {
          "from": "/sequencer"
        }
      },
      "type": "voicer"
    },
    {
      "address": "/osc",
      "inputs": {
        "freq": {
          "from": "/voicer.freq"
        }
      },
      "type": "oscillator"
    },
    {
      "address": "/filter",
      "inputs": {
        "audio": {
          "from": "/osc"
        },
        "cutoff": 2500.0
      },
      "type": "filter"
    },
    {
      "address": "/env",
      "inputs": {
        "attack": 0.005,
        "decay": 0.14,
        "gate": {
          "from": "/voicer.gate"
        },
        "release": 0.1,
        "sustain": 0.3
      },
      "type": "envelope"
    },
    {
      "address": "/env_curve",
      "doc": "Shape the linear envelope CV into an exponential-style volume curve (x^2).",
      "inputs": {
        "x": {
          "from": "/env"
        }
      },
      "type": "power_f32_signal"
    },
    {
      "address": "/env_vca",
      "doc": "VCA: audio * shaped envelope CV.",
      "inputs": {
        "a": {
          "from": "/filter"
        },
        "b": {
          "from": "/env_curve"
        }
      },
      "type": "mul_f32_signal"
    },
    {
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/env_vca"
        }
      },
      "type": "output"
    }
  ],
  "outputs": [
    {
      "node": "/out",
      "port": "audio"
    }
  ]
}
