{
  "format_version": 3,
  "instrument": "granulator-demo",
  "resources": {
    "src": "samples/testvoice.wav"
  },
  "interface": {
    "inputs": {
      "position": {
        "type": "f32",
        "default": 0.25,
        "min": 0.0,
        "max": 1.0
      },
      "grain_size": {
        "type": "f32",
        "default": 120.0,
        "min": 5.0,
        "max": 500.0,
        "unit": "ms"
      },
      "pitch": {
        "type": "f32",
        "default": -5.0,
        "min": -24.0,
        "max": 24.0,
        "unit": "st"
      },
      "density": {
        "type": "f32",
        "default": 30.0,
        "min": 1.0,
        "max": 200.0,
        "curve": "exp",
        "unit": "Hz"
      },
      "spray": {
        "type": "f32",
        "default": 50.0,
        "min": 0.0,
        "max": 1000.0,
        "unit": "ms"
      },
      "gain": {
        "type": "f32",
        "default": 1.0,
        "min": 0.0,
        "max": 4.0
      }
    },
    "outputs": {
      "out": {
        "from": "/out.audio"
      }
    }
  },
  "nodes": [
    {
      "type": "granulator",
      "address": "/grain",
      "inputs": {
        "density": {
          "from": "/density"
        },
        "gain": {
          "from": "/gain"
        },
        "grain_size": {
          "from": "/grain_size"
        },
        "pitch": {
          "from": "/pitch"
        },
        "position": {
          "from": "/position"
        },
        "spray": {
          "from": "/spray"
        },
        "window": "Hann"
      },
      "sample": "src"
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/grain.audio"
        }
      }
    }
  ]
}
