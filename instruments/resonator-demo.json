{
  "doc": "Throwaway: clock gate pings the resonator on every beat.",
  "instrument": "ping-resonator",
  "nodes": [
    { "address": "/clock", "inputs": { "tempo": 120.0 }, "type": "clock" },
    { "address": "/res", "type": "resonator",
      "inputs": { "freq": 220.0, "gate": { "from": "/clock.gate" },
        "structure": 0.2, "brightness": 0.6, "damping": 0.8, "position": 0.3 } },
    { "address": "/out", "inputs": { "audio": { "from": "/res" } }, "type": "output" }
  ],
  "outputs": [ { "node": "/out", "port": "audio" } ]
}