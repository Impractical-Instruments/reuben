{
  "format_version": 2,
  "instrument": "euclidean-drums",
  "doc": "A self-playing 4-channel Euclidean rhythm machine (kick, snare, tom, hat). One shared clock (division=4 -> a 16th-note grid) drives four `euclid` generators; each spreads its `pulses` hits evenly across `steps` (with `rotation` to shift the phase) and emits a gate that fires that channel's drum voice. Every voice is synthesized from operators (no samples), gated straight off the euclid gate like the metronome -- kick = sine body + decaying pitch-drop, snare = noise + tonal ring, tom = a boomier higher kick, hat = highpassed noise tick. Per channel you get: Euclidean controls (steps/pulses/rotation), a DECAY knob (the amp envelope's decay -- on kick/tom it stretches both the tail and the pitch sweep), a bipolar DJ FILTER knob (-1 lowpass down .. 0 open .. +1 highpass up), and a LEVEL knob. The four channels sum through a master trim to the output. Ride tempo via /clock/tempo; reshape patterns via /<chan>_eu/pulses, /<chan>_eu/steps, /<chan>_eu/rotation; sweep tone via /<chan>_filter/in [-1..1]; set loudness via /<chan>_level/in [0..1]; set tail via /<chan>_env/decay.",
  "interface": {
    "outputs": {
      "out": {
        "from": "/out.audio"
      }
    }
  },
  "nodes": [
    {
      "type": "clock",
      "address": "/clock",
      "doc": "Shared timing. division=4 -> the gate pulses 4x per beat (a 16th-note grid) that clocks every euclid.",
      "inputs": {
        "division": 4.0,
        "tempo": 120.0
      },
      "control": {
        "label": "Tempo",
        "param": "tempo",
        "widget": "radial"
      }
    },
    {
      "type": "euclid",
      "address": "/kick_eu",
      "doc": "Kick Euclidean generator. E(16,4,0) = four-on-the-floor (a pulse every 4 steps).",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": 4.0,
        "rotation": 0.0,
        "steps": 16.0
      },
      "control": [
        {
          "group": "kick",
          "label": "Kick Pulses",
          "param": "pulses",
          "widget": "radial"
        },
        {
          "group": "kick",
          "label": "Kick Steps",
          "param": "steps",
          "widget": "radial"
        },
        {
          "group": "kick",
          "label": "Kick Rotation",
          "param": "rotation",
          "widget": "radial"
        }
      ]
    },
    {
      "type": "envelope",
      "address": "/kick_env",
      "doc": "Kick amp+pitch envelope, gated by the euclid pulse. `decay` is the DECAY control: longer = boomier tail AND longer pitch drop.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.0,
        "gate": {
          "from": "/kick_eu.gate"
        },
        "release": 0.08,
        "sustain": 1.0
      },
      "control": {
        "group": "kick",
        "label": "Kick Decay",
        "param": "decay",
        "widget": "radial"
      }
    },
    {
      "type": "m2s",
      "address": "/kick_sweep_amt",
      "doc": "Constant pitch-sweep amount (Hz).",
      "inputs": {
        "in": 220.0
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/kick_penv",
      "doc": "Sweep amount * envelope CV -> the decaying pitch drop.",
      "inputs": {
        "a": {
          "from": "/kick_sweep_amt"
        },
        "b": {
          "from": "/kick_env.cv"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/kick_base",
      "doc": "Constant kick base frequency (Hz).",
      "inputs": {
        "in": 48.0
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/kick_freq",
      "doc": "kick freq = base + decaying sweep.",
      "inputs": {
        "a": {
          "from": "/kick_base"
        },
        "b": {
          "from": "/kick_penv"
        }
      }
    },
    {
      "type": "oscillator",
      "address": "/kick_osc",
      "doc": "Sine body, frequency driven by the pitch-drop.",
      "inputs": {
        "freq": {
          "from": "/kick_freq"
        },
        "waveform": "Sine"
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/kick_curve",
      "doc": "Exponential-style volume curve (x^2) on the amp CV.",
      "inputs": {
        "x": {
          "from": "/kick_env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/kick_vca",
      "doc": "VCA: kick body * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/kick_osc"
        },
        "b": {
          "from": "/kick_curve"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/kick_filter",
      "doc": "Kick DJ-filter position knob [-1..1], smoothed (zipper-free).",
      "inputs": {
        "in": 0.0,
        "mode": "Smooth",
        "time": 0.1
      },
      "control": {
        "default": 0.0,
        "group": "kick",
        "label": "Kick DJ Filter",
        "max": 1.0,
        "min": -1.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "djfilter",
      "address": "/kick_dj",
      "doc": "Per-channel DJ filter on the kick. position driven by the smoothed knob.",
      "inputs": {
        "audio": {
          "from": "/kick_vca"
        },
        "position": {
          "from": "/kick_filter"
        },
        "resonance": 0.25
      }
    },
    {
      "type": "m2s",
      "address": "/kick_level",
      "doc": "Kick LEVEL knob [0..1], smoothed into a CV.",
      "inputs": {
        "in": 0.85,
        "mode": "Smooth",
        "time": 0.02
      },
      "control": {
        "default": 0.85,
        "group": "kick",
        "label": "Kick Level",
        "max": 1.0,
        "min": 0.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/kick_amp",
      "doc": "kick audio * level CV.",
      "inputs": {
        "a": {
          "from": "/kick_dj"
        },
        "b": {
          "from": "/kick_level"
        }
      }
    },
    {
      "type": "euclid",
      "address": "/snare_eu",
      "doc": "Snare Euclidean generator. E(16,2,4) = the backbeat (steps 5 and 13).",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": 2.0,
        "rotation": 4.0,
        "steps": 16.0
      },
      "control": [
        {
          "group": "snare",
          "label": "Snare Pulses",
          "param": "pulses",
          "widget": "radial"
        },
        {
          "group": "snare",
          "label": "Snare Steps",
          "param": "steps",
          "widget": "radial"
        },
        {
          "group": "snare",
          "label": "Snare Rotation",
          "param": "rotation",
          "widget": "radial"
        }
      ]
    },
    {
      "type": "envelope",
      "address": "/snare_env",
      "doc": "Snare amp envelope, gated by the euclid pulse. `decay` is the DECAY control (snap length).",
      "inputs": {
        "attack": 0.001,
        "decay": 0.0,
        "gate": {
          "from": "/snare_eu.gate"
        },
        "release": 0.06,
        "sustain": 1.0
      },
      "control": {
        "group": "snare",
        "label": "Snare Decay",
        "param": "decay",
        "widget": "radial"
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/snare_curve",
      "doc": "Exponential-style volume curve (x^2) on the amp CV.",
      "inputs": {
        "x": {
          "from": "/snare_env.cv"
        }
      }
    },
    {
      "type": "noise",
      "address": "/snare_noise",
      "doc": "Snare noise body."
    },
    {
      "type": "mul_f32_signal",
      "address": "/snare_noise_vca",
      "doc": "VCA: noise * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/snare_noise"
        },
        "b": {
          "from": "/snare_curve"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/snare_tone_f",
      "doc": "Constant tonal frequency (Hz) for the snare's ring.",
      "inputs": {
        "in": 185.0
      }
    },
    {
      "type": "oscillator",
      "address": "/snare_osc",
      "doc": "Tonal component (sine) under the noise.",
      "inputs": {
        "freq": {
          "from": "/snare_tone_f"
        },
        "waveform": "Sine"
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/snare_tone_vca",
      "doc": "VCA: tone * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/snare_osc"
        },
        "b": {
          "from": "/snare_curve"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/snare_mix",
      "doc": "snare = noise body + tonal ring.",
      "inputs": {
        "a": {
          "from": "/snare_noise_vca"
        },
        "b": {
          "from": "/snare_tone_vca"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/snare_filter",
      "doc": "Snare DJ-filter position knob [-1..1], smoothed.",
      "inputs": {
        "in": 0.0,
        "mode": "Smooth",
        "time": 0.1
      },
      "control": {
        "default": 0.0,
        "group": "snare",
        "label": "Snare DJ Filter",
        "max": 1.0,
        "min": -1.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "djfilter",
      "address": "/snare_dj",
      "doc": "Per-channel DJ filter on the snare.",
      "inputs": {
        "audio": {
          "from": "/snare_mix"
        },
        "position": {
          "from": "/snare_filter"
        },
        "resonance": 0.25
      }
    },
    {
      "type": "m2s",
      "address": "/snare_level",
      "doc": "Snare LEVEL knob [0..1], smoothed into a CV.",
      "inputs": {
        "in": 0.6,
        "mode": "Smooth",
        "time": 0.02
      },
      "control": {
        "default": 0.6,
        "group": "snare",
        "label": "Snare Level",
        "max": 1.0,
        "min": 0.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/snare_amp",
      "doc": "snare audio * level CV.",
      "inputs": {
        "a": {
          "from": "/snare_dj"
        },
        "b": {
          "from": "/snare_level"
        }
      }
    },
    {
      "type": "euclid",
      "address": "/tom_eu",
      "doc": "Tom Euclidean generator. E(16,3,2) = three hits spread across the bar, shifted for a fill feel.",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": 3.0,
        "rotation": 2.0,
        "steps": 16.0
      },
      "control": [
        {
          "group": "tom",
          "label": "Tom Pulses",
          "param": "pulses",
          "widget": "radial"
        },
        {
          "group": "tom",
          "label": "Tom Steps",
          "param": "steps",
          "widget": "radial"
        },
        {
          "group": "tom",
          "label": "Tom Rotation",
          "param": "rotation",
          "widget": "radial"
        }
      ]
    },
    {
      "type": "envelope",
      "address": "/tom_env",
      "doc": "Tom amp+pitch envelope, gated by the euclid pulse. `decay` is the DECAY control: longer = boomier tail AND longer pitch drop.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.0,
        "gate": {
          "from": "/tom_eu.gate"
        },
        "release": 0.12,
        "sustain": 1.0
      },
      "control": {
        "group": "tom",
        "label": "Tom Decay",
        "param": "decay",
        "widget": "radial"
      }
    },
    {
      "type": "m2s",
      "address": "/tom_sweep_amt",
      "doc": "Constant pitch-sweep amount (Hz) -- gentler than the kick.",
      "inputs": {
        "in": 120.0
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/tom_penv",
      "doc": "Sweep amount * envelope CV -> the tom's decaying pitch drop.",
      "inputs": {
        "a": {
          "from": "/tom_sweep_amt"
        },
        "b": {
          "from": "/tom_env.cv"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/tom_base",
      "doc": "Constant tom base frequency (Hz) -- higher than the kick.",
      "inputs": {
        "in": 130.0
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/tom_freq",
      "doc": "tom freq = base + decaying sweep.",
      "inputs": {
        "a": {
          "from": "/tom_base"
        },
        "b": {
          "from": "/tom_penv"
        }
      }
    },
    {
      "type": "oscillator",
      "address": "/tom_osc",
      "doc": "Sine body, frequency driven by the pitch-drop.",
      "inputs": {
        "freq": {
          "from": "/tom_freq"
        },
        "waveform": "Sine"
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/tom_curve",
      "doc": "Exponential-style volume curve (x^2) on the amp CV.",
      "inputs": {
        "x": {
          "from": "/tom_env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/tom_vca",
      "doc": "VCA: tom body * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/tom_osc"
        },
        "b": {
          "from": "/tom_curve"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/tom_filter",
      "doc": "Tom DJ-filter position knob [-1..1], smoothed.",
      "inputs": {
        "in": 0.0,
        "mode": "Smooth",
        "time": 0.1
      },
      "control": {
        "default": 0.0,
        "group": "tom",
        "label": "Tom DJ Filter",
        "max": 1.0,
        "min": -1.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "djfilter",
      "address": "/tom_dj",
      "doc": "Per-channel DJ filter on the tom.",
      "inputs": {
        "audio": {
          "from": "/tom_vca"
        },
        "position": {
          "from": "/tom_filter"
        },
        "resonance": 0.25
      }
    },
    {
      "type": "m2s",
      "address": "/tom_level",
      "doc": "Tom LEVEL knob [0..1], smoothed into a CV.",
      "inputs": {
        "in": 0.6,
        "mode": "Smooth",
        "time": 0.02
      },
      "control": {
        "default": 0.6,
        "group": "tom",
        "label": "Tom Level",
        "max": 1.0,
        "min": 0.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/tom_amp",
      "doc": "tom audio * level CV.",
      "inputs": {
        "a": {
          "from": "/tom_dj"
        },
        "b": {
          "from": "/tom_level"
        }
      }
    },
    {
      "type": "euclid",
      "address": "/hat_eu",
      "doc": "Hat Euclidean generator. E(16,8,0) = straight offbeat 8ths (every other step).",
      "inputs": {
        "clock": {
          "from": "/clock.gate"
        },
        "pulses": 8.0,
        "rotation": 0.0,
        "steps": 16.0
      },
      "control": [
        {
          "group": "hat",
          "label": "Hat Pulses",
          "param": "pulses",
          "widget": "radial"
        },
        {
          "group": "hat",
          "label": "Hat Steps",
          "param": "steps",
          "widget": "radial"
        },
        {
          "group": "hat",
          "label": "Hat Rotation",
          "param": "rotation",
          "widget": "radial"
        }
      ]
    },
    {
      "type": "noise",
      "address": "/hat_noise",
      "doc": "Hat noise source."
    },
    {
      "type": "filter",
      "address": "/hat_hp",
      "doc": "Highpass to thin the noise into a metallic hat.",
      "inputs": {
        "audio": {
          "from": "/hat_noise"
        },
        "cutoff": 7000.0,
        "mode": "Hp",
        "resonance": 0.1
      }
    },
    {
      "type": "envelope",
      "address": "/hat_env",
      "doc": "Very short hat amp envelope, gated by the euclid pulse. `decay` is the DECAY control: short tick .. open hat.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.0,
        "gate": {
          "from": "/hat_eu.gate"
        },
        "release": 0.03,
        "sustain": 1.0
      },
      "control": {
        "group": "hat",
        "label": "Hat Decay",
        "param": "decay",
        "widget": "radial"
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/hat_curve",
      "doc": "Exponential-style volume curve (x^2) on the hat CV.",
      "inputs": {
        "x": {
          "from": "/hat_env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/hat_vca",
      "doc": "VCA: hat noise * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/hat_hp"
        },
        "b": {
          "from": "/hat_curve"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/hat_filter",
      "doc": "Hat DJ-filter position knob [-1..1], smoothed.",
      "inputs": {
        "in": 0.0,
        "mode": "Smooth",
        "time": 0.1
      },
      "control": {
        "default": 0.0,
        "group": "hat",
        "label": "Hat DJ Filter",
        "max": 1.0,
        "min": -1.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "djfilter",
      "address": "/hat_dj",
      "doc": "Per-channel DJ filter on the hat.",
      "inputs": {
        "audio": {
          "from": "/hat_vca"
        },
        "position": {
          "from": "/hat_filter"
        },
        "resonance": 0.25
      }
    },
    {
      "type": "m2s",
      "address": "/hat_level",
      "doc": "Hat LEVEL knob [0..1], smoothed into a CV.",
      "inputs": {
        "in": 0.5,
        "mode": "Smooth",
        "time": 0.02
      },
      "control": {
        "default": 0.5,
        "group": "hat",
        "label": "Hat Level",
        "max": 1.0,
        "min": 0.0,
        "param": "in",
        "widget": "radial"
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/hat_amp",
      "doc": "hat audio * level CV.",
      "inputs": {
        "a": {
          "from": "/hat_dj"
        },
        "b": {
          "from": "/hat_level"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix_a",
      "doc": "kick + snare.",
      "inputs": {
        "a": {
          "from": "/kick_amp"
        },
        "b": {
          "from": "/snare_amp"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix_b",
      "doc": "tom + hat.",
      "inputs": {
        "a": {
          "from": "/tom_amp"
        },
        "b": {
          "from": "/hat_amp"
        }
      }
    },
    {
      "type": "add_f32_signal",
      "address": "/mix",
      "doc": "(kick+snare) + (tom+hat) -> full kit mix.",
      "inputs": {
        "a": {
          "from": "/mix_a"
        },
        "b": {
          "from": "/mix_b"
        }
      }
    },
    {
      "type": "m2s",
      "address": "/trim_cv",
      "doc": "Constant master trim (headroom so overlapping hits don't clip).",
      "inputs": {
        "in": 0.7
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/trim",
      "doc": "master audio * trim CV -> headroom.",
      "inputs": {
        "a": {
          "from": "/mix"
        },
        "b": {
          "from": "/trim_cv"
        }
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/trim"
        }
      }
    }
  ]
}
