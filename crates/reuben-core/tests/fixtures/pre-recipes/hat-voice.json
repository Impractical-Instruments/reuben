{
  "format_version": 2,
  "instrument": "hat-voice",
  "doc": "Hi-hat voice. A gate fires a short envelope shaping highpassed noise into a metallic tick. Pitch is internal (no freq interface input); the host's lane voicer only drives the gate. interface: gate in, audio/active out.",
  "interface": {
    "inputs": {
      "gate": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 1.0
      }
    },
    "outputs": {
      "active": {
        "from": "/env.active"
      },
      "audio": {
        "from": "/out.audio"
      }
    }
  },
  "nodes": [
    {
      "type": "noise",
      "address": "/noise",
      "doc": "Hat noise source."
    },
    {
      "type": "filter",
      "address": "/hp",
      "doc": "Highpass to thin the noise into a metallic hat.",
      "inputs": {
        "audio": {
          "from": "/noise"
        },
        "cutoff": 7000.0,
        "mode": "Hp",
        "resonance": 0.1
      }
    },
    {
      "type": "envelope",
      "address": "/env",
      "doc": "Very short amplitude envelope -> linear CV -> tick.",
      "inputs": {
        "attack": 0.001,
        "decay": 0.04,
        "gate": {
          "from": "/gate"
        },
        "release": 0.03,
        "sustain": 0.0
      }
    },
    {
      "type": "power_f32_signal",
      "address": "/curve",
      "doc": "Exponential-style volume curve (x^2) on the hat CV.",
      "inputs": {
        "x": {
          "from": "/env.cv"
        }
      }
    },
    {
      "type": "mul_f32_signal",
      "address": "/vca",
      "doc": "VCA: hat noise * shaped amp CV.",
      "inputs": {
        "a": {
          "from": "/hp"
        },
        "b": {
          "from": "/curve"
        }
      }
    },
    {
      "type": "output",
      "address": "/out",
      "inputs": {
        "audio": {
          "from": "/vca"
        }
      }
    }
  ]
}
