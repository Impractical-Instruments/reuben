{
  "format_version": 3,
  "instrument": "euclidean-drums",
  "doc": "A self-playing 4-channel Euclidean rhythm machine (kick, snare, tom, hat). One shared clock (division=4 -> a 16th-note grid) drives four `euclid` generators; each spreads its `pulses` hits evenly across `steps` (with `rotation` to shift the phase) and emits a gate that fires that channel's drum voice. Every voice is synthesized from operators (no samples), gated straight off the euclid gate like the metronome -- kick = sine body + decaying pitch-drop, snare = noise + tonal ring, tom = a boomier higher kick, hat = highpassed noise tick. Per channel you get: Euclidean controls (steps/pulses/rotation), a DECAY knob (the amp envelope's decay -- on kick/tom it stretches both the tail and the pitch sweep), a bipolar DJ FILTER knob (-1 lowpass down .. 0 open .. +1 highpass up), and a LEVEL knob. The four channels sum through a master trim to the output. Every knob is an interface input pipe (presentation lives in surfaces/euclidean-drums.json): ride tempo via /tempo/in; reshape patterns via /<chan>_pulses/in, /<chan>_steps/in, /<chan>_rotation/in; sweep tone via /<chan>_filter/in [-1..1]; set loudness via /<chan>_level/in [0..1]; set tail via /<chan>_decay/in. The smoothed filter/level CVs live on the internal /<chan>_filter_cv and /<chan>_level_cv nodes. The four <chan>_decay pipes declare default 0.001 rather than the retired inline literal 0.0: the loader coerce-clamped that literal to the envelope's range floor, so 0.001 IS the old effective rest value (a pipe default outside its declared range is a load error) \u2014 bit-identity is asserted in format_v3_rewrite.rs.",
  "interface": {
    "inputs": {
      "tempo": {
        "type": "f32",
        "default": 120.0,
        "min": 1.0,
        "max": 999.0,
        "unit": "BPM"
      },
      "kick_pulses": {
        "type": "f32",
        "default": 4.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "kick_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "kick_rotation": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "kick_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "kick_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "kick_level": {
        "type": "f32",
        "default": 0.85,
        "min": 0.0,
        "max": 1.0
      },
      "snare_pulses": {
        "type": "f32",
        "default": 2.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "snare_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "snare_rotation": {
        "type": "f32",
        "default": 4.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "snare_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "snare_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "snare_level": {
        "type": "f32",
        "default": 0.6,
        "min": 0.0,
        "max": 1.0
      },
      "tom_pulses": {
        "type": "f32",
        "default": 3.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "tom_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "tom_rotation": {
        "type": "f32",
        "default": 2.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "tom_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "tom_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "tom_level": {
        "type": "f32",
        "default": 0.6,
        "min": 0.0,
        "max": 1.0
      },
      "hat_pulses": {
        "type": "f32",
        "default": 8.0,
        "min": 0.0,
        "max": 16.0,
        "unit": "pulses"
      },
      "hat_steps": {
        "type": "f32",
        "default": 16.0,
        "min": 1.0,
        "max": 16.0,
        "unit": "steps"
      },
      "hat_rotation": {
        "type": "f32",
        "default": 0.0,
        "min": 0.0,
        "max": 15.0,
        "unit": "steps"
      },
      "hat_decay": {
        "type": "f32",
        "default": 0.001,
        "min": 0.001,
        "max": 5.0,
        "unit": "s"
      },
      "hat_filter": {
        "type": "f32",
        "default": 0.0,
        "min": -1.0,
        "max": 1.0
      },
      "hat_level": {
        "type": "f32",
        "default": 0.5,
        "min": 0.0,
        "max": 1.0
      }
    },
    "outputs": {
